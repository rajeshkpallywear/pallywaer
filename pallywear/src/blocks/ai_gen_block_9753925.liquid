{% doc %}
  @prompt
    Create a compact, centered customer enquiry form with small-sized input fields and button. Include: customer name input, customer phone number input, customer email input, file upload button, comment text box, and send enquiry button. All form elements should be compact with reduced padding and height. Center the entire form on the page and make it mobile-responsive.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-enquiry-form-container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 50vh;
    padding: 20px;
    background-color: {{ block.settings.container_background }};
  }

  .ai-enquiry-form-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.form_width }}px;
    padding: {{ block.settings.form_padding }}px;
    background-color: {{ block.settings.form_background }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-enquiry-form__title-{{ ai_gen_id }} {
    text-align: center;
    margin: 0 0 20px 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
  }

  .ai-enquiry-form__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-enquiry-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-enquiry-form__label-{{ ai_gen_id }} {
    font-size:12px;
    color: {{ block.settings.label_color }};
    font-weight: 500;
  }

  .ai-enquiry-form__input-{{ ai_gen_id }},
  .ai-enquiry-form__textarea-{{ ai_gen_id }},
  .ai-enquiry-form__file-{{ ai_gen_id }} {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 14px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    box-sizing: border-box;
    transition: border-color 0.2s ease;
  }

  .ai-enquiry-form__input-{{ ai_gen_id }}:focus,
  .ai-enquiry-form__textarea-{{ ai_gen_id }}:focus,
  .ai-enquiry-form__file-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.input_focus_border }};
  }

  .ai-enquiry-form__textarea-{{ ai_gen_id }} {
    min-height: 80px;
    resize: vertical;
    font-family: inherit;}

  .ai-enquiry-form__file-{{ ai_gen_id }} {
    padding: 6px 12px;
    cursor: pointer;
  }

  .ai-enquiry-form__button-{{ ai_gen_id }} {
    width: 100%;
    padding: 10px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease;
    margin-top: 8px;
  }

  .ai-enquiry-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-enquiry-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-size: 14px;
    text-align: center;
    margin-top: 12px;
  }

  .ai-enquiry-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 12px;
    margin-top: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-enquiry-form-container-{{ ai_gen_id }} {
      padding: 15px;
      min-height: auto;
    }

    .ai-enquiry-form-{{ ai_gen_id }} {
      padding: 20px;
    }

    .ai-enquiry-form__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;margin-bottom: 16px;
    }

    .ai-enquiry-form__input-{{ ai_gen_id }},
    .ai-enquiry-form__textarea-{{ ai_gen_id }},
    .ai-enquiry-form__file-{{ ai_gen_id }} {
      padding: 10px 12px;
    }
  }
{% endstyle %}

<div class="ai-enquiry-form-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-enquiry-form-{{ ai_gen_id }}">
    {%- if block.settings.form_title != blank -%}
      <h2 class="ai-enquiry-form__title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h2>
    {%- endif -%}

    {%- form 'contact'-%}
      <input type="hidden" name="contact[enquiry_type]" value="customer_enquiry">
      <div class="ai-enquiry-form__content-{{ ai_gen_id }}">
        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label for="ai-enquiry-name-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
            {{ block.settings.name_label }}
          </label>
          <input
            type="text"
            id="ai-enquiry-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.name }}"
            placeholder="{{ block.settings.name_placeholder }}"
            required
          >
          {%- if form.errors.name -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">{{ form.errors.name }}</div>
          {%- endif -%}
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label for="ai-enquiry-phone-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}
          </label>
          <input
            type="tel"
            id="ai-enquiry-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.phone }}"
            placeholder="{{ block.settings.phone_placeholder }}"
          >
          {%- if form.errors.phone -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">{{ form.errors.phone }}</div>
          {%- endif -%}
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label for="ai-enquiry-email-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
            {{ block.settings.email_label }}
          </label>
          <input
            type="email"
            id="ai-enquiry-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            placeholder="{{ block.settings.email_placeholder }}"
            required
          >
          {%- if form.errors.email -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">{{ form.errors.email }}</div>
          {%- endif -%}
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label for="ai-enquiry-file-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
            {{ block.settings.file_label }}
          </label>
          <input
            type="file"
            id="ai-enquiry-file-{{ ai_gen_id }}"
            name="contact[attachment]"
            class="ai-enquiry-form__file-{{ ai_gen_id }}"
            accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif">
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label for="ai-enquiry-message-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
            {{ block.settings.message_label }}
          </label>
          <textarea
            id="ai-enquiry-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-enquiry-form__textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
          >{{ form.body }}</textarea>
          {%- if form.errors.body -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">{{ form.errors.body }}</div>
          {%- endif -%}
        </div>

        <button type="submit" class="ai-enquiry-form__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </button>

        {%- if form.posted_successfully? -%}
          <div class="ai-enquiry-form__success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}
      </div>
    {%- endform -%}
  </div>
</div>

