{% doc %}
  @prompt
    Create a compact customer enquiry form with small-sized input fields and button. Include: customer name input, customer phone number input, customer email input, file upload button, comment text box, and send enquiry button. All form elements should be compact and small in size with reduced padding and height. Make it mobile-responsive., make it center

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-enquiry-form-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    padding: 20px;
  }

  .ai-enquiry-form-{{ ai_gen_id }} {
    max-width: 400px;
    width: 100%;
    padding: 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-enquiry-form__title-{{ ai_gen_id }} {
    margin: 0 0 16px 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    font-weight: 600;
    text-align: center;
  }

  .ai-enquiry-form__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-enquiry-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-enquiry-form__label-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    font-weight: 500;
  }

  .ai-enquiry-form__input-{{ ai_gen_id }},
  .ai-enquiry-form__textarea-{{ ai_gen_id }},
  .ai-enquiry-form__file-{{ ai_gen_id }} {
    width: 100%;
    padding: 8px 10px;
    font-size: 13px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    box-sizing: border-box;
    transition: border-color 0.2s ease;
  }

  .ai-enquiry-form__input-{{ ai_gen_id }}:focus,
  .ai-enquiry-form__textarea-{{ ai_gen_id }}:focus,
  .ai-enquiry-form__file-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.focus_border_color }};
  }

  .ai-enquiry-form__textarea-{{ ai_gen_id }} {
    height: 60px;
    resize: vertical;
    min-height: 40px;
    max-height: 120px;
  }

  .ai-enquiry-form__file-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-enquiry-form__file-{{ ai_gen_id }} {
    cursor: pointer;
  }

  .ai-enquiry-form__file-{{ ai_gen_id }}::file-selector-button {
    background-color: {{ block.settings.file_button_color }};
    color: {{ block.settings.file_button_text_color }};
    border: none;
    padding: 4px 8px;
    border-radius: 3px;
    font-size: 11px;
    cursor: pointer;
    margin-right: 8px;}

  .ai-enquiry-form__button-{{ ai_gen_id }} {
    padding: 10px 16px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s ease;
    margin-top: 4px;
    width: 100%;
  }

  .ai-enquiry-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-enquiry-form__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    font-size: 12px;
    margin-top: 8px;
    padding: 8px;
    background-color: {{ block.settings.success_background }};
    border-radius: 4px;
    text-align: center;
  }

  .ai-enquiry-form__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    font-size: 12px;
    margin-top: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-enquiry-form-wrapper-{{ ai_gen_id }} {
      padding: 16px;
    }

    .ai-enquiry-form-{{ ai_gen_id }} {
      max-width: 100%;
      padding: 16px;
    }

    .ai-enquiry-form__input-{{ ai_gen_id }},
    .ai-enquiry-form__textarea-{{ ai_gen_id }},
    .ai-enquiry-form__file-{{ ai_gen_id }} {
      padding: 6px 8px;
      font-size: 12px;
    }

    .ai-enquiry-form__button-{{ ai_gen_id }} {
      padding: 8px 14px;
      font-size: 12px;
    }

    .ai-enquiry-form__textarea-{{ ai_gen_id }} {
      height: 50px;
    }
  }
{% endstyle %}

<div
  class="ai-enquiry-form-wrapper-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-enquiry-form-{{ ai_gen_id }}">
    {%- form 'contact' -%}
      <input type="hidden" name="contact[enquiry_type]" value="customer_enquiry">
      <div class="ai-enquiry-form__content-{{ ai_gen_id }}">
        {%- if block.settings.form_title != blank -%}
          <h3 class="ai-enquiry-form__title-{{ ai_gen_id }}">{{ block.settings.form_title }}</h3>
        {%- endif -%}<div class="ai-enquiry-form__field-{{ ai_gen_id }}"><label class="ai-enquiry-form__label-{{ ai_gen_id }}" for="enquiry-name-{{ ai_gen_id }}">
            {{ block.settings.name_label }}
          </label>
          <input
            type="text"
            id="enquiry-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.name }}"
            placeholder="{{ block.settings.name_placeholder }}"
            required
          >
          {%- if form.errors.name -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">
              {{ form.errors.name }}
            </div>
          {%- endif -%}
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label class="ai-enquiry-form__label-{{ ai_gen_id }}" for="enquiry-phone-{{ ai_gen_id }}">
            {{ block.settings.phone_label }}
          </label>
          <input
            type="tel"
            id="enquiry-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.phone }}"
            placeholder="{{ block.settings.phone_placeholder }}"
          >
          {%- if form.errors.phone -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">
              {{ form.errors.phone }}
            </div>
          {%- endif -%}
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label class="ai-enquiry-form__label-{{ ai_gen_id }}" for="enquiry-email-{{ ai_gen_id }}">
            {{ block.settings.email_label }}
          </label>
          <input
            type="email"
            id="enquiry-email-{{ ai_gen_id }}"
            name="contact[email]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            placeholder="{{ block.settings.email_placeholder }}"
            autocomplete="email"
            required
          >
          {%- if form.errors.email -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">
              {{ form.errors.email }}
            </div>
          {%- endif -%}
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label class="ai-enquiry-form__label-{{ ai_gen_id }}" for="enquiry-file-{{ ai_gen_id }}">
            {{ block.settings.file_label }}
          </label>
          <div class="ai-enquiry-form__file-wrapper-{{ ai_gen_id }}">
            <input
              type="file"
              id="enquiry-file-{{ ai_gen_id }}"
              name="contact[attachment]"
              class="ai-enquiry-form__file-{{ ai_gen_id }}"
              accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif"
            >
          </div>
        </div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label class="ai-enquiry-form__label-{{ ai_gen_id }}" for="enquiry-message-{{ ai_gen_id }}">
            {{ block.settings.message_label }}
          </label>
          <textarea
            id="enquiry-message-{{ ai_gen_id }}"
            name="contact[body]"
            class="ai-enquiry-form__textarea-{{ ai_gen_id }}"
            placeholder="{{ block.settings.message_placeholder }}"
            required
          >{{ form.body }}</textarea>
          {%- if form.errors.body -%}
            <div class="ai-enquiry-form__error-{{ ai_gen_id }}">
              {{ form.errors.body }}
            </div>
          {%- endif -%}
        </div>

        <button
          type="submit"
          class="ai-enquiry-form__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </button>

        {%- if form.posted_successfully? -%}
          <div class="ai-enquiry-form__success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {%- endif -%}
      </div>
    {%- endform -%}
  </div>
</div>

