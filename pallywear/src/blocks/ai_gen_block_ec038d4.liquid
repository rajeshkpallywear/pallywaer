{% doc %}
  @prompt
    Create an enquiry form block with Customer Name, Customer Number, Customer Email Id, Upload File option, Comment Box, and Send button. Design it to be positioned before the footer section. Make it professional, mobile-responsive, and visually appealing

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-enquiry-form-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .ai-enquiry-form__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-enquiry-form__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-enquiry-form__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;}

  .ai-enquiry-form__form-{{ ai_gen_id }} {
    display: grid;
    gap: 24px;}

  .ai-enquiry-form__row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .ai-enquiry-form__field-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-enquiry-form__field--full-{{ ai_gen_id }} {
    grid-column: 1 / -1;
  }

  .ai-enquiry-form__label-{{ ai_gen_id }} {
    font-size:14px;
    font-weight: 500;
    color: {{ block.settings.text_color }};}

  .ai-enquiry-form__required-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
  }

  .ai-enquiry-form__input-{{ ai_gen_id }},
  .ai-enquiry-form__textarea-{{ ai_gen_id }} {
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: 16px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.text_color }};
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-enquiry-form__input-{{ ai_gen_id }}:focus,
  .ai-enquiry-form__textarea-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
    box-shadow: 0 0 0 3px {{ block.settings.accent_color }}33;
  }

  .ai-enquiry-form__textarea-{{ ai_gen_id }} {
    min-height: 120px;
    resize: vertical;font-family: inherit;
  }

  .ai-enquiry-form__file-wrapper-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
    width: 100%;
  }

  .ai-enquiry-form__file-input-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
    width: 100%;
    height: 100%;
    cursor: pointer;
  }

  .ai-enquiry-form__file-label-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
    border: 2px dashed {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.text_color }};
    cursor: pointer;
    transition: all 0.3s ease;text-align: center;
  }

  .ai-enquiry-form__file-label-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.accent_color }};
    background-color: {{ block.settings.accent_color }}11;
  }

  .ai-enquiry-form__file-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;opacity: 0.6;
  }

  .ai-enquiry-form__file-text-{{ ai_gen_id }} {
    font-size: 14px;
  }

  .ai-enquiry-form__file-name-{{ ai_gen_id }} {
    margin-top: 8px;
    font-size: 14px;
    color: {{ block.settings.accent_color }};font-weight: 500;
  }

  .ai-enquiry-form__button-{{ ai_gen_id }} {
    padding: 16px 32px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    justify-self: center;
    min-width: 200px;
  }

  .ai-enquiry-form__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-enquiry-form__button-{{ ai_gen_id }}:active {
    transform: translateY(0);
  }

  .ai-enquiry-form__success-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.success_color }}22;
    border: 1px solid {{ block.settings.success_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    color: {{ block.settings.success_color }};
    text-align: center;
    margin-top: 16px;
  }

  .ai-enquiry-form__error-{{ ai_gen_id }} {
    padding: 16px;
    background-color: {{ block.settings.error_color }}22;
    border: 1px solid {{ block.settings.error_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    color: {{ block.settings.error_color }};
    text-align: center;
    margin-top: 16px;
  }

  @media screen and (max-width: 768px) {
    .ai-enquiry-form-{{ ai_gen_id }} {
      padding: 24px 16px;
    }

    .ai-enquiry-form__row-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .ai-enquiry-form__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-enquiry-form__button-{{ ai_gen_id }} {
      width: 100%;min-width: auto;
    }
  }
{% endstyle %}

<enquiry-form-{{ ai_gen_id }}
  class="ai-enquiry-form-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-enquiry-form__header-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-enquiry-form__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <p class="ai-enquiry-form__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>

  {% form 'contact' %}
    <div class="ai-enquiry-form__form-{{ ai_gen_id }}">
      <div class="ai-enquiry-form__row-{{ ai_gen_id }}">
        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label for="customer-name-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
            Customer Name <span class="ai-enquiry-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="text"
            id="customer-name-{{ ai_gen_id }}"
            name="contact[name]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.name }}"
            placeholder="Enter your full name"
            required
            {% if form.errors contains 'name' %}
              aria-invalid="true"
              aria-describedby="name-error-{{ ai_gen_id }}"
            {% endif %}
          ></div>

        <div class="ai-enquiry-form__field-{{ ai_gen_id }}">
          <label for="customer-phone-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
            Phone Number <span class="ai-enquiry-form__required-{{ ai_gen_id }}">*</span>
          </label>
          <input
            type="tel"
            id="customer-phone-{{ ai_gen_id }}"
            name="contact[phone]"
            class="ai-enquiry-form__input-{{ ai_gen_id }}"
            value="{{ form.phone }}"
            placeholder="Enter your phone number"
            required
            {% if form.errors contains 'phone' %}
              aria-invalid="true"
              aria-describedby="phone-error-{{ ai_gen_id }}"
            {% endif %}
          >
        </div>
      </div>

      <div class="ai-enquiry-form__field-{{ ai_gen_id }} ai-enquiry-form__field--full-{{ ai_gen_id }}">
        <label for="customer-email-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
          Email Address <span class="ai-enquiry-form__required-{{ ai_gen_id }}">*</span>
        </label>
        <input
          type="email"
          id="customer-email-{{ ai_gen_id }}"
          name="contact[email]"
          class="ai-enquiry-form__input-{{ ai_gen_id }}"
          value="{{ form.email }}"
          placeholder="Enter your email address"
          required
          autocomplete="email"
          {% if form.errors contains 'email' %}
            aria-invalid="true"
            aria-describedby="email-error-{{ ai_gen_id }}"
          {% endif %}
        >
      </div>

      <div class="ai-enquiry-form__field-{{ ai_gen_id }} ai-enquiry-form__field--full-{{ ai_gen_id }}">
        <label for="file-upload-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
          Upload File (Optional)
        </label>
        <div class="ai-enquiry-form__file-wrapper-{{ ai_gen_id }}">
          <input
            type="file"
            id="file-upload-{{ ai_gen_id }}"
            name="contact[file]"
            class="ai-enquiry-form__file-input-{{ ai_gen_id }}"
            accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.gif">
          <label for="file-upload-{{ ai_gen_id }}" class="ai-enquiry-form__file-label-{{ ai_gen_id }}">
            <svg class="ai-enquiry-form__file-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
            </svg>
            <span class="ai-enquiry-form__file-text-{{ ai_gen_id }}">Click to upload or drag and drop</span>
          </label>
          <div class="ai-enquiry-form__file-name-{{ ai_gen_id }}" style="display: none;"></div>
        </div>
      </div>

      <div class="ai-enquiry-form__field-{{ ai_gen_id }} ai-enquiry-form__field--full-{{ ai_gen_id }}">
        <label for="customer-message-{{ ai_gen_id }}" class="ai-enquiry-form__label-{{ ai_gen_id }}">
          Comments <span class="ai-enquiry-form__required-{{ ai_gen_id }}">*</span>
        </label>
        <textarea
          id="customer-message-{{ ai_gen_id }}"
          name="contact[body]"
          class="ai-enquiry-form__textarea-{{ ai_gen_id }}"
          placeholder="Please describe your enquiry in detail..."
          required
          {% if form.errors contains 'body' %}
            aria-invalid="true"
            aria-describedby="message-error-{{ ai_gen_id }}"
          {% endif %}
        >{{ form.body }}</textarea>
      </div>

      <button type="submit" class="ai-enquiry-form__button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </button>

      {% if form.posted_successfully? %}
        <div class="ai-enquiry-form__success-{{ ai_gen_id }}">
          {{ block.settings.success_message }}
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="ai-enquiry-form__error-{{ ai_gen_id }}">
          {% for field in form.errors %}
            <p>{{ field | capitalize }} {{ form.errors.messages[field] }}</p>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  {% endform %}
</enquiry-form-{{ ai_gen_id }}>

<script>
  (function() {
    class EnquiryForm{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.fileInput = this.querySelector('.ai-enquiry-form__file-input-{{ ai_gen_id }}');
        this.fileLabel = this.querySelector('.ai-enquiry-form__file-label-{{ ai_gen_id }}');
        this.fileName = this.querySelector('.ai-enquiry-form__file-name-{{ ai_gen_id }}');
        this.setupFileUpload();
      }

      setupFileUpload() {
        if (!this.fileInput) return;

        this.fileInput.addEventListener('change', (event) => {
          const file = event.target.files[0];
          if (file) {
            this.fileName.textContent = `Selected: ${file.name}`;
            this.fileName.style.display = 'block';this.fileLabel.style.borderColor = '{{ block.settings.accent_color }}';
            this.fileLabel.style.backgroundColor = '{{ block.settings.accent_color }}11';
          } else {
            this.fileName.style.display = 'none';
            this.fileLabel.style.borderColor = '{{ block.settings.input_border_color }}';
            this.fileLabel.style.backgroundColor = '{{ block.settings.input_background_color }}';
          }
        });

        this.fileLabel.addEventListener('dragover', (event) => {
          event.preventDefault();
          this.fileLabel.style.borderColor = '{{ block.settings.accent_color }}';
          this.fileLabel.style.backgroundColor = '{{ block.settings.accent_color }}22';
        });

        this.fileLabel.addEventListener('dragleave', () => {
          this.fileLabel.style.borderColor = '{{ block.settings.input_border_color }}';
          this.fileLabel.style.backgroundColor = '{{ block.settings.input_background_color }}';
        });

        this.fileLabel.addEventListener('drop', (event) => {
          event.preventDefault();
          const files = event.dataTransfer.files;
          if (files.length > 0) {
            this.fileInput.files = files;
            const changeEvent = new Event('change', { bubbles: true });
            this.fileInput.dispatchEvent(changeEvent);
          }
        });
      }
    }

    customElements.define('enquiry-form-{{ ai_gen_id }}', EnquiryForm{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Customer Enquiry Form",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Form heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Form subtitle",
      "default": "We'd love to hear from you. Send us a message and we'll respond as soon as possible."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Send Enquiry"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for your enquiry! We'll get back to you soon."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1d1d1d"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "input_background_color",
      "label": "Input background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "input_border_color",
      "label": "Input border color",
      "default": "#d1d5db"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button hover color",
      "default": "#1d4ed8"
    },
    {
      "type": "color",
      "id": "success_color",
      "label": "Success color",
      "default": "#059669"
    },
    {
      "type": "color",
      "id": "error_color",
      "label": "Error color",
      "default": "#dc2626"
